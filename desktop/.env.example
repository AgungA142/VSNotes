# =============================================================================
# VSNotes — Desktop (Electron) Environment Variables
# =============================================================================
# Salin file ini ke .env dan sesuaikan nilainya.
# File ini dibaca oleh Electron main process dan Vite (renderer).

# =============================================================================
# BACKEND API URL
# =============================================================================

# URL backend untuk Electron main process
# Development: http://localhost:3000
# Production : https://api.vsnotes.app
API_BASE_URL=http://localhost:3000

# URL backend untuk renderer process (Vite) — wajib prefix VITE_
VITE_API_BASE_URL=http://localhost:3000
