{
  "name": "vsnotes",
  "version": "1.0.0",
  "private": true,
  "description": "VSNotes - Monorepo",
  "scripts": {
    "dev": "pnpm --filter desktop dev",
    "build": "pnpm --filter desktop build",
    "server:dev": "pnpm --filter backend dev",
    "server:start": "pnpm --filter backend start",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter video-summary-notes-web build",
    "test": "pnpm -r test",
    "test:pbt": "pnpm -r test:pbt",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "neverBuiltDependencies": ["better-sqlite3", "puppeteer"]
  }
}
