# =============================================================================
# VSNotes — Backend Environment Variables
# =============================================================================
# Salin file ini ke .env dan isi dengan nilai yang sesuai.
# Variabel tanpa # wajib diisi. Variabel dengan # bersifat opsional.

# =============================================================================
# DATABASE
# =============================================================================

# MongoDB Atlas — production
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vsnotes?retryWrites=true&w=majority

# MongoDB lokal — development
MONGODB_URI=mongodb://127.0.0.1:27017/vsnotes

# =============================================================================
# AI / TRANSCRIPTION
# =============================================================================


# Google Gemini API key — wajib
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key — wajib 
GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# AUTHENTICATION
# =============================================================================

# JWT secret key — minimal 32 karakter, gunakan string acak yang kuat
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret_minimum_32_characters_long_here
JWT_EXPIRES_IN=7d

# =============================================================================
# EMAIL / SMTP — Brevo (brevo.com)
# =============================================================================
# Setup:
#   1. Daftar di brevo.com
#   2. Senders & IPs → Add a new sender → verifikasi email kamu
#   3. SMTP & API → SMTP → Generate a new SMTP Key
#
# PENTING: SMTP_USER dan FROM_EMAIL harus diisi dengan email yang SAMA
#          (email yang sudah diverifikasi sebagai sender di Brevo)
#
# Jika SMTP_HOST kosong, link reset password di-log ke console (dev only).

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_verified_email@example.com
SMTP_PASS=your_brevo_smtp_key_here          # format: xsmtpsib-...
FROM_EMAIL=your_verified_email@example.com  # wajib sama dengan SMTP_USER

APP_URL=http://localhost:3000               # ganti ke URL production saat deploy

# =============================================================================
# SERVER
# =============================================================================

PORT=3000
NODE_ENV=development

# CORS origins yang diizinkan (pisahkan dengan koma)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# AUDIO PROCESSING
# =============================================================================

AUDIO_CHUNK_SIZE_SEC=30
AUDIO_SAMPLE_RATE=16000

# =============================================================================
# CLOUD STORAGE (opsional — untuk chunk audio sementara)
# =============================================================================

# STORAGE_BUCKET=your_bucket_name
# STORAGE_REGION=us-east-1

# =============================================================================
# LOGGING
# =============================================================================

# Level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info
