# =============================================================================
# VSNotes — Backend Environment Variables
# =============================================================================
# Salin file ini ke backend/.env dan isi dengan nilai yang sesuai.
# Variabel tanpa tanda # wajib diisi. Variabel dengan # bersifat opsional.

# =============================================================================
# DATABASE
# =============================================================================

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/vsnotes?retryWrites=true&w=majority

# =============================================================================
# AI / TRANSCRIPTION
# =============================================================================

# Provider transkripsi: 'gemini' (default) atau 'groq'
TRANSCRIPTION_PROVIDER=gemini

# Google Gemini API key — wajib jika TRANSCRIPTION_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key — wajib jika TRANSCRIPTION_PROVIDER=groq
# GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# AUTHENTICATION
# =============================================================================

# JWT secret key — minimal 32 karakter, gunakan string acak yang kuat
JWT_SECRET=your_jwt_secret_minimum_32_characters_long_here
JWT_EXPIRES_IN=7d

# =============================================================================
# EMAIL / SMTP (untuk fitur lupa password)
# =============================================================================
# Jika SMTP_HOST tidak diisi, link reset password akan di-log ke console (dev only).
# Rekomendasi untuk production: Resend (resend.com) atau Brevo.

# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here
# FROM_EMAIL=noreply@yourdomain.com

# URL aplikasi — digunakan untuk membuat link reset password di email
# APP_URL=https://api.vsnotes.app

# =============================================================================
# SERVER
# =============================================================================

PORT=3000
NODE_ENV=development

# CORS origins yang diizinkan (pisahkan dengan koma)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# AUDIO PROCESSING
# =============================================================================

AUDIO_CHUNK_SIZE_SEC=30
AUDIO_SAMPLE_RATE=16000

# =============================================================================
# CLOUD STORAGE (opsional — untuk chunk audio sementara)
# =============================================================================

# STORAGE_BUCKET=your_bucket_name
# STORAGE_REGION=us-east-1

# =============================================================================
# LOGGING
# =============================================================================

# Level: error | warn | info | http | verbose | debug | silly
LOG_LEVEL=info
